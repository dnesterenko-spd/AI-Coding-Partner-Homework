{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github@latest"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_MCP_TOKEN}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@latest",
        "/Users/dima/Work/Projects/AI-Coding-Partner-Homework/homework-5"
      ]
    },
    "jira": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e", "JIRA_URL",
        "-e", "JIRA_USERNAME",
        "-e", "JIRA_API_TOKEN",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "env": {
        "JIRA_URL": "${ATLASSIAN_URL}",
        "JIRA_USERNAME": "${ATLASSIAN_EMAIL}",
        "JIRA_API_TOKEN": "${ATLASSIAN_API_TOKEN}"
      }
    },
    "lorem-ipsum": {
      "command": "python3",
      "args": [
        "/Users/dima/Work/Projects/AI-Coding-Partner-Homework/homework-5/custom-mcp-server/server.py"
      ]
    }
  }
}