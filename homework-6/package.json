{
  "name": "banking-transaction-pipeline",
  "version": "1.0.0",
  "description": "3-agent Node.js/TypeScript pipeline for validating and processing banking transactions",
  "main": "pipeline.ts",
  "scripts": {
    "pipeline": "ts-node pipeline.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:coverage:check": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":80,\"functions\":80,\"lines\":80,\"statements\":80}}'",
    "prepush": "npm run test:coverage:check",
    "validator": "ts-node agents/transaction_validator.ts",
    "fraud-detector": "ts-node agents/fraud_detector.ts",
    "reporter": "ts-node agents/reporting_agent.ts",
    "mcp": "ts-node mcp/server.ts"
  },
  "keywords": [
    "banking",
    "transaction",
    "validation",
    "fraud-detection"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "decimal.js": "^10.4.3",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "fastmcp": "^3.34.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
